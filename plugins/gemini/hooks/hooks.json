{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" SessionStart",
            "timeout": 20000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" BeforeAgent",
            "timeout": 20000
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" BeforeModel",
            "timeout": 20000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" AfterAgent",
            "timeout": 20000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" BeforeTool",
            "timeout": 20000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" AfterTool",
            "timeout": 20000
          }
        ]
      }
    ],
    "BeforeToolSelection": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" BeforeToolSelection",
            "timeout": 20000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" SessionEnd",
            "timeout": 20000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" Notification",
            "timeout": 20000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}${/}scripts${/}hook.mjs\" PreCompress",
            "timeout": 20000
          }
        ]
      }
    ]
  }
}
