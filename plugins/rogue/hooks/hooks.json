{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '( nohup sh \"$CLAUDE_PLUGIN_ROOT/scripts/auto-update.sh\" >/dev/null 2>&1 & )' ; exit 0",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -Command \"Start-Process powershell -WindowStyle Hidden -ArgumentList '-NoProfile','-NonInteractive','-Command','& ([scriptblock]::Create((Get-Content -Raw -LiteralPath (Join-Path (Get-Item Env:CLAUDE_PLUGIN_ROOT).Value ''scripts/auto-update.ps1''))))'\" ; exit 0",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
